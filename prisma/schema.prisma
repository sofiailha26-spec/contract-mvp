generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contract {
  id                    String   @id @default(cuid())
  name                  String
  pdfUrl                String
  pdfData               String?  @db.Text   // base64 encoded PDF data (for Vercel serverless)

  // Signature positioning (saved from drag-and-drop UI)
  adminSignX            Float?
  adminSignY            Float?
  adminSignPage         Int?

  creatorSignX          Float?
  creatorSignY          Float?
  creatorSignPage       Int?

  creatorSignatureUrl   String?
  creatorName           String?
  adminSignatureUrl     String?
  adminName             String?
  status                String   @default("pending_creator") // pending_creator, pending_admin, completed
  token                 String   @unique
  createdAt             DateTime @default(now())
}
