generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contract {
  id                    String   @id @default(cuid())
  name                  String
  pdfUrl                String
  creatorSignatureUrl   String?
  creatorName           String?
  adminSignatureUrl     String?
  adminName             String?
  status                String   @default("pending_creator") // pending_creator, pending_admin, completed
  token                 String   @unique
  createdAt             DateTime @default(now())
}
